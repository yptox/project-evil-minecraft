### 11.3 VRGazeProvider.cs
```csharp
using UnityEngine;
using UnityEngine.XR;

namespace AlgorithmicGallery
{
    public class VRGazeProvider : MonoBehaviour, IGazeProvider
    {
        public bool IsAvailable { get; private set; }

        private Camera _camera;
        private InputDevice _hmdDevice;

        private void OnEnable()
        {
            _camera = GetComponent<Camera>();
            if (_camera == null)
            {
                Debug.LogError("VRGazeProvider must be attached to a GameObject with a Camera component.");
                IsAvailable = false;
                return;
            }

            var xrDevices = new System.Collections.Generic.List<InputDevice>();
            InputDevices.GetDevicesWithCharacteristics(
                InputDeviceCharacteristics.HeadMounted,
                xrDevices
            );

            if (xrDevices.Count > 0)
            {
                _hmdDevice = xrDevices[0];
                IsAvailable = _hmdDevice.isValid;
            }
            else
            {
                IsAvailable = false;
            }

            if (!IsAvailable)
            {
                Debug.LogWarning("VRGazeProvider: No XR HMD device found. Will use camera forward as fallback.");
            }
        }

        private void OnDisable()
        {
            IsAvailable = false;
        }

        public Ray GetGazeRay()
        {
            if (_hmdDevice.isValid)
            {
                if (_hmdDevice.TryGetFeatureValue(CommonUsages.centerEyePosition, out Vector3 hmdPosition))
                {
                    if (_hmdDevice.TryGetFeatureValue(CommonUsages.centerEyeRotation, out Quaternion hmdRotation))
                    {
                        return new Ray(hmdPosition, hmdRotation * Vector3.forward);
                    }
                }
            }

            return new Ray(_camera.transform.position, _camera.transform.forward);
        }
    }
}
```

### 11.4 GazeManager.cs
```csharp
using UnityEngine;

namespace AlgorithmicGallery
{
    public class GazeManager : MonoBehaviour
    {
        [Header("Configuration")]
        [SerializeField] private float _dwellThreshold = 0.6f;
        [SerializeField] private float _gazeExitGracePeriod = 0.3f;
        [SerializeField] private float _maxRayDistance = 50f;

        [Header("References")]
        [SerializeField] private GalleryManager _galleryManager;

        private IGazeProvider _gazeProvider;
        private SculptureController _currentGazeTarget;
        private SculptureController _previousGazeTarget;
        private float _currentDwellTime;
        private float _gazeExitTimer;
        private bool _isWaitingForGazeExit;

        private void Start()
        {
            _gazeProvider = GetComponent<VRGazeProvider>();
            if (_gazeProvider == null || !_gazeProvider.IsAvailable)
                _gazeProvider = GetComponent<DesktopGazeProvider>();

            if (_gazeProvider == null || !_gazeProvider.IsAvailable)
            {
                var desktopProvider = gameObject.AddComponent<DesktopGazeProvider>();
                _gazeProvider = desktopProvider;
                Debug.Log("GazeManager: Auto-added DesktopGazeProvider.");
            }

            if (_galleryManager == null)
                _galleryManager = FindFirstObjectByType<GalleryManager>();

            _currentGazeTarget = null;
            _previousGazeTarget = null;
            _currentDwellTime = 0f;
            _gazeExitTimer = 0f;
            _isWaitingForGazeExit = false;
        }

        private void Update()
        {
            if (_gazeProvider == null || !_gazeProvider.IsAvailable) return;

            Ray gazeRay = _gazeProvider.GetGazeRay();
            SculptureController hitTarget = null;

            if (Physics.Raycast(gazeRay, out RaycastHit hit, _maxRayDistance))
            {
                hitTarget = hit.collider.GetComponent<SculptureController>();
                if (hitTarget == null)
                    hitTarget = hit.collider.GetComponentInParent<SculptureController>();
            }

            if (hitTarget == _currentGazeTarget && hitTarget != null)
            {
                _isWaitingForGazeExit = false;
                _currentDwellTime += Time.deltaTime;
                if (_currentDwellTime >= _dwellThreshold)
                    _currentGazeTarget.OnGazeDwell(_currentDwellTime);
                return;
            }

            if (hitTarget != _currentGazeTarget)
            {
                if (_currentGazeTarget != null && !_isWaitingForGazeExit)
                {
                    _isWaitingForGazeExit = true;
                    _previousGazeTarget = _currentGazeTarget;
                    _gazeExitTimer = 0f;
                }

                if (hitTarget != null)
                {
                    ConfirmGazeExit();
                    _currentGazeTarget = hitTarget;
                    _currentDwellTime = 0f;
                }
            }

            if (_isWaitingForGazeExit && hitTarget == null)
            {
                _gazeExitTimer += Time.deltaTime;
                if (_gazeExitTimer >= _gazeExitGracePeriod)
                {
                    ConfirmGazeExit();
                    _currentGazeTarget = null;
                    _currentDwellTime = 0f;
                }
            }
        }

        private void ConfirmGazeExit()
        {
            if (!_isWaitingForGazeExit) return;

            if (_previousGazeTarget != null)
            {
                _previousGazeTarget.OnGazeExit();
                if (_galleryManager != null)
                    _galleryManager.OnSculptureGazeExit(_previousGazeTarget);
            }

            _previousGazeTarget = null;
            _isWaitingForGazeExit = false;
            _gazeExitTimer = 0f;
        }

        public SculptureController CurrentGazeTarget => _currentGazeTarget;
        public float CurrentDwellTime => _currentDwellTime;
    }
}
```

### 11.5 SculptureController.cs
```csharp
using UnityEngine;

namespace AlgorithmicGallery
{
    [RequireComponent(typeof(Collider))]
    public class SculptureController : MonoBehaviour
    {
        private enum SculptureState { Seed, Blooming, FullBloom, Decaying, Dead }

        [Header("Configuration")]
        [SerializeField] private float _bloomDuration = 2f;
        [SerializeField] private float _decayDuration = 4f;
        [SerializeField] private float _breathePulseSpeed = 2f;
        [SerializeField] private float _breathePulseAmount = 0.05f;
        [SerializeField] private float _maxEmissionPower = 2f;

        [Header("References")]
        [SerializeField] private Renderer _renderer;

        public string ModelId { get; set; }
        public float TotalDwellMs { get; private set; }

        private SculptureState _state;
        private float _stateTimer;
        private float _bloomProgress;
        private MaterialPropertyBlock _propertyBlock;
        private Vector3 _originalScale;
        private Renderer[] _allRenderers;

        private void OnEnable()
        {
            if (_renderer == null)
                _renderer = GetComponentInChildren<Renderer>();
            _allRenderers = GetComponentsInChildren<Renderer>();

            _propertyBlock = new MaterialPropertyBlock();
            _originalScale = transform.localScale;
            _state = SculptureState.Seed;
            _stateTimer = 0f;
            _bloomProgress = 0f;
            TotalDwellMs = 0f;

            ApplySeedState();
        }

        private void Update()
        {
            _stateTimer += Time.deltaTime;

            switch (_state)
            {
                case SculptureState.Seed: break;
                case SculptureState.Blooming: UpdateBlooming(); break;
                case SculptureState.FullBloom: UpdateFullBloom(); break;
                case SculptureState.Decaying: UpdateDecaying(); break;
                case SculptureState.Dead: break;
            }
        }

        public void OnGazeDwell(float dwellTimeSeconds)
        {
            TotalDwellMs = dwellTimeSeconds * 1000f;
            if (_state == SculptureState.Seed)
                TransitionToBlooming();
        }

        public void OnGazeExit()
        {
            if (_state == SculptureState.Blooming || _state == SculptureState.FullBloom)
                TransitionToDecaying();
        }

        private void TransitionToBlooming() { _state = SculptureState.Blooming; _stateTimer = 0f; _bloomProgress = 0f; }
        private void TransitionToFullBloom() { _state = SculptureState.FullBloom; _stateTimer = 0f; _bloomProgress = 1f; ApplyBloomState(1f); }
        private void TransitionToDecaying() { _state = SculptureState.Decaying; _stateTimer = 0f; }
        private void TransitionToDead()
        {
            _state = SculptureState.Dead;
            if (_renderer != null) _renderer.enabled = false;
            GetComponent<Collider>().enabled = false;
        }

        private void ApplyPropertyToAllRenderers()
        {
            if (_allRenderers == null) return;
            foreach (var r in _allRenderers)
                if (r != null) r.SetPropertyBlock(_propertyBlock);
        }

        private void ApplySeedState()
        {
            _propertyBlock.SetFloat("_Saturation", 0f);
            _propertyBlock.SetFloat("_EmissionPower", 0f);
            _propertyBlock.SetFloat("_DissolveAmount", 0f);
            ApplyPropertyToAllRenderers();
            transform.localScale = _originalScale * 0.9f;
        }

        private void UpdateBlooming()
        {
            _bloomProgress = Mathf.Clamp01(_stateTimer / _bloomDuration);
            if (_bloomProgress >= 1f) TransitionToFullBloom();
            else ApplyBloomState(_bloomProgress);
        }

        private void ApplyBloomState(float bloomProgress)
        {
            _propertyBlock.SetFloat("_Saturation", bloomProgress);
            _propertyBlock.SetFloat("_EmissionPower", Mathf.Lerp(0f, _maxEmissionPower, bloomProgress));
            _propertyBlock.SetFloat("_DissolveAmount", 0f);
            ApplyPropertyToAllRenderers();
            float targetScale = Mathf.Lerp(0.9f, 1f, bloomProgress);
            transform.localScale = _originalScale * targetScale;
        }

        private void UpdateFullBloom()
        {
            float breathe = Mathf.Sin(_stateTimer * _breathePulseSpeed) * _breathePulseAmount;
            transform.localScale = _originalScale * (1f + breathe);
        }

        private void UpdateDecaying()
        {
            float decayProgress = Mathf.Clamp01(_stateTimer / _decayDuration);
            if (decayProgress >= 1f) TransitionToDead();
            else ApplyDecayState(decayProgress);
        }

        private void ApplyDecayState(float decayProgress)
        {
            _propertyBlock.SetFloat("_Saturation", 1f - decayProgress);
            _propertyBlock.SetFloat("_EmissionPower", Mathf.Lerp(_maxEmissionPower, 0f, decayProgress));
            _propertyBlock.SetFloat("_DissolveAmount", decayProgress);
            ApplyPropertyToAllRenderers();
            float decayScale = Mathf.Lerp(1f, 0.5f, decayProgress);
            transform.localScale = _originalScale * decayScale;
        }
    }
